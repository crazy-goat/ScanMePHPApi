        "php": ">=8.1",
        "workerman/webman": "^1.5",
        "crazy-goat/scanmephp": "^0.4.11",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "allow-plugins": {
            "crazy-goat/scanmephp": true
        }
    }
}
